{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Node",
        "target": "ESNext",
        "esModuleInterop": true,
        "allowImportingTsExtensions": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "checkJs": true,
        "strict": true
    },
    "include": [
        "**/*.mjs"
    ],
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}
